# ─────────────────────────────────────────────────────────────
# Face Recognition MVP — Variáveis de Ambiente
# Copie este arquivo para .env e edite conforme necessário:
#   cp .env.example .env
# ─────────────────────────────────────────────────────────────

# ── Servidor ──────────────────────────────────────────────────
PORT=5000

# ── Reconhecimento Facial ─────────────────────────────────────
# Menor = mais rigoroso (0.40 a 0.60)
RECOGNITION_TOLERANCE=0.50

# ── Evolution API (WhatsApp) ──────────────────────────────────
EVOLUTION_API_URL=http://localhost:8080
EVOLUTION_API_KEY=B6D711FCDE4D4FD5936544120E713976
EVOLUTION_INSTANCE=face_mvp

# ── Números de telefone ───────────────────────────────────────
# Formato: DDI + DDD + Número (sem + ou espaços)
SENDER_PHONE=5514998338034
DEFAULT_RECIPIENT=5514997283283

# ── Twilio SMS (alternativo — deixe vazio para usar Evolution API)
USE_TWILIO=false
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM=+15514998338034

# ── Modo de teste: true = não envia mensagens reais ───────────
MOCK_MESSAGES=false
