# ─────────────────────────────────────────────────────────────
# Face Recognition MVP — Variáveis de Ambiente
# Copie este arquivo para .env e edite conforme necessário:
#   cp .env.example .env
# ─────────────────────────────────────────────────────────────

# ── Servidor ──────────────────────────────────────────────────
PORT=5000

# ── Reconhecimento Facial ─────────────────────────────────────
# Menor = mais rigoroso (0.40 a 0.60)
RECOGNITION_TOLERANCE=0.50

# ── WhatsApp Business (Meta Cloud API) ────────────────────────
# Canal principal — sem Docker, direto na nuvem da Meta
#
# Como obter:
#   1. https://developers.facebook.com/apps/ → Criar App (Business)
#   2. Adicionar produto: WhatsApp
#   3. WhatsApp → Configuração da API → copiar Token e Phone Number ID
#
USE_META_WHATSAPP=true
META_WHATSAPP_TOKEN=           # Token de acesso (temporário ou permanente)
META_PHONE_NUMBER_ID=          # ID do número de telefone (ex: 123456789012345)
META_API_VERSION=v19.0         # Versão da Graph API

# ── Números de telefone ───────────────────────────────────────
# Formato: DDI + DDD + Número (sem + ou espaços)
SENDER_PHONE=551xxxxxxxx
DEFAULT_RECIPIENT=55xxxxxxx

# ── Evolution API (WhatsApp open-source via Docker) ───────────
# Legado — use apenas se preferir rodar localmente com Docker
EVOLUTION_API_URL=http://localhost:8080
EVOLUTION_API_KEY=xxxxxxxxxxxxxx
EVOLUTION_INSTANCE=face_mvp

# ── Twilio SMS (alternativo — deixe vazio para usar Meta API) ─
USE_TWILIO=false
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM=+155149xxxxxxxxx

# ── Modo de teste: true = não envia mensagens reais ───────────
MOCK_MESSAGES=false

# ── Webhook de auditoria de presença ─────────────────────────
WEBHOOK_URL=
WEBHOOK_SECRET=
WEBHOOK_TIMEOUT_SECONDS=1.5
WEBHOOK_RETRY_MAX=2
